# Structs Network
NETWORK_VERSION=113b
NETWORK_CHAIN_ID=structstestnet-111
STRUCTSD_ARGUMENTS=--log_level info

# Network Resources
STRUCTS_NODE_API_SEED=https://public.testnet.structs.network
STRUCTS_RPC_SEED=https://public.testnet.structs.network:26657
STRUCTS_RPC_PRIMARY=http://structsd:26657

# Guild Stack Config
WEBAPP_SOURCE=../structs-webapp/src
PROXY_HTTP_PORT=80
DIRECT_WEBAPP_HTTP_PORT=8080
DIRECT_WEBAPP_HTTPS_PORT=443
DIRECT_POSTGRES_PORT=5432
WEBAPP_APP_ENV=dev
WEBAPP_APP_DEBUG=3
WEBAPP_APP_SECRET=<generate-a-strong-random-secret>

# structs-control (admin SPA — dev bind mount, sibling checkout)
CONTROL_SOURCE=../structs-control
DIRECT_CONTROL_HTTP_PORT=8081
CONTROL_DEV_GALLERY=
CONTROL_CHOKIDAR_POLLING=true

# Database Config
DATABASE_NAME=structs
AUTO_MIGRATE_SLEEP=120
SQITCH_PG_CONNECTION=postgres://structs@structs-pg:5432/structs
STRUCTS_PG_BRANCH=main


# Node Details
## A single string without spaces denoting the node identifier
MONIKER=

# Validation Details
GUILD_MNEMONIC=
VALIDATOR_INITIAL_STAKING_AMOUNT=50000000
VALIDATOR_IDENTITY=
VALIDATOR_COMMISSION_RATE=0.10
VALIDATOR_MAX_RATE=0.20
VALIDATOR_MAX_CHANGE_RATE=0.01
VALIDATOR_MIN_SELF_DELEGATION=1


# Guild Details
GUILD_ID=
GUILD_NAME=
GUILD_DESCRIPTION=
GUILD_TAG=
GUILD_LOGO=
GUILD_SOCIALS={"twitter":"","facebook":"","farcaster":""}
GUILD_WEBSITE=
GUILD_CONTACT=

## Denominations Power:Label
### 0=Smallest Value
### Ex... {"0": "penny",  "3": "dollar"}
###       {"0": "ualpha", "6": "alpha"}
###       {"0": "uatom",  "6": "atom"}
GUILD_DENOM={"0": "utoken", "6": "token"}


# Discord Details
DISCORD_CLIENT_ID=
DISCORD_TOKEN=

# MCP
MCP_DANGER=true